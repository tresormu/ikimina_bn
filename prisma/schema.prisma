generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  MEMBER
  TREASURER
  ADMIN
}

enum GroupFrequency {
  WEEKLY
  BIWEEKLY
  MONTHLY
}

enum GroupType {
  ROTATING_EQUAL
  ACCUMULATING_SHARES
  ROTATING_AUCTION
  SOLIDARITY_FUND
  INVESTMENT_CLUB
  HYBRID_ROTATING_SAVINGS
}

enum ContributionModel {
  FIXED_EQUAL
  FLEXIBLE_SHARES
  FIXED_SPLIT
}

enum RotationType {
  SEQUENTIAL
  RANDOM_DRAW
  AUCTION
  GROUP_VOTE
}

enum PenaltyType {
  NONE
  FIXED_FINE
  PERCENTAGE_FINE
  TURN_LOSS
}

enum GroupLanguage {
  KINYARWANDA
  ENGLISH
  FRENCH
}

enum DisbursementType {
  GRANT
  LOAN
  MIXED
}

enum ContributionStatus {
  PENDING
  VERIFIED
  LATE
  MISSED
  DISPUTED
  WAIVED
}

enum LoanStatus {
  PENDING
  APPROVED
  DECLINED
  REPAID
  DEFAULTED
}

enum UssdSessionState {
  OPEN
  CONTINUE
  CLOSED
}

enum NotificationType {
  CONTRIBUTION_CONFIRMED
  CONTRIBUTION_FAILED
  CONTRIBUTION_REMINDER
  CONTRIBUTION_OVERDUE
  MISSED_PAYMENT
  YOUR_TURN
  PAYOUT_SCHEDULED
  LOAN_APPROVED
  LOAN_DECLINED
  LOAN_REPAYMENT_DUE
  LOAN_REPAYMENT_LATE
  LOAN_DEFAULT
  WEEKLY_REMINDER
  SUBSCRIPTION_TRIAL_ENDING
  SUBSCRIPTION_PAYMENT_DUE
  SUBSCRIPTION_PAYMENT_SUCCESS
  SUBSCRIPTION_PAYMENT_FAILED
  SUBSCRIPTION_GRACE_PERIOD_WARNING
  GROUP_SUSPENDED
  GROUP_REACTIVATED
  SUBSCRIPTION_TIER_UPGRADED
  SUBSCRIPTION_TIER_DOWNGRADED
  DISPUTE_OPENED
  DISPUTE_RESOLVED
  GROUP_ANNOUNCEMENT
  BILLING_REMINDER
}

enum NotificationChannel {
  SMS
  PUSH
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  PERMANENTLY_FAILED
}

enum DisputeStatus {
  OPEN
  RESOLVED
  ESCALATED
  CLOSED
}

enum DisputeType {
  CONTRIBUTION_NOT_RECORDED
  WRONG_AMOUNT_RECORDED
  PAYOUT_DISPUTE
  LOAN_DISPUTE
  ROTATION_ORDER_DISPUTE
  TREASURER_MISCONDUCT
}

enum SubscriptionTier {
  STARTER
  GROWTH
  COMMUNITY
  ENTERPRISE
  MEGA
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  OVERDUE
  SUSPENDED
  ARCHIVED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  CONFIRMED
  FAILED
}

enum WaitlistStatus {
  WAITING
  INVITED
  EXPIRED
}

model User {
  id              String    @id @default(uuid())
  phoneNumber     String    @unique
  fullName        String?
  nationalId      String?   @unique
  profilePhotoUrl String?
  roles           Role[]    @default([MEMBER])
  isActive        Boolean   @default(true)
  deletedAt       DateTime?
  referralCode    String?   @unique  // treasurer's personal referral code

  refreshTokens        RefreshToken[]
  groupMembers         GroupMember[]
  contributions        Contribution[]
  loansRequested       Loan[]
  notifications        Notification[]
  notificationSettings NotificationSetting[]
  sharedCreditReports  SharedCreditReport[]
  disputesRaised       Dispute[]
  ussdSessions         UssdSession[]
  auditLogs            AuditLog[]
  subscriptionPayments SubscriptionPayment[]
  memberPenalties      MemberPenalty[]
  auctionBids          AuctionBid[]
  memberShareBalances  MemberShareBalance[]
  waitlistEntries      WaitlistEntry[]
  referralsMade        ReferralLog[]         @relation("Referrer")
  referralsReceived    ReferralLog[]         @relation("ReferredUser")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OtpRecord {
  id             String    @id @default(uuid())
  phoneNumber    String
  hashedOtp      String
  expiresAt      DateTime
  failedAttempts Int       @default(0)
  lockedUntil    DateTime?
  createdAt      DateTime  @default(now())

  @@index([phoneNumber, createdAt])
  @@index([expiresAt])
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  revoked   Boolean  @default(false)
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@index([userId, revoked, expiresAt])
  @@index([expiresAt])
}

model Group {
  id                 String             @id @default(uuid())
  name               String
  frequency          GroupFrequency
  inviteCode         String             @unique
  bankName           String?
  bankAccountName    String?
  bankAccountNumber  String?
  subscriptionStatus SubscriptionStatus @default(TRIAL)
  isSuspended        Boolean            @default(false)
  suspendedAt        DateTime?
  suspensionReason   String?
  deletedAt          DateTime?

  // Group type configuration
  groupType         GroupType         @default(ROTATING_EQUAL)
  contributionModel ContributionModel @default(FIXED_EQUAL)

  // For FIXED_EQUAL and FIXED_SPLIT (Int = RWF, no decimals)
  contributionAmount Int?
  rotatingAmount     Int?
  savingsAmount      Int?

  // For FLEXIBLE_SHARES
  sharePrice         Int?
  maxSharesPerMember Int?

  // Rotation configuration
  rotationType       RotationType @default(SEQUENTIAL)
  rotationIndex      Int          @default(0)
  currentCycleNumber Int          @default(1)
  auctionWindowHours Int?
  minBidPercentage   Int?

  // Loan configuration
  loansEnabled        Boolean  @default(true)
  loanMinTenureMonths Int      @default(6)
  loanMaxPercentage   Int      @default(30)
  loanInterestRate    Decimal? @db.Decimal(5, 2)

  // Penalty configuration
  gracePeriodDays     Int         @default(3)
  latePenaltyType     PenaltyType @default(NONE)
  latePenaltyAmount   Int?
  missesBeforeRemoval Int         @default(3)

  // Language preference
  language GroupLanguage @default(KINYARWANDA)

  // Solidarity/Emergency fund config
  emergencyCategories String[]
  disbursementType    DisbursementType?
  maxDisbursement     Int?

  // Registration (Ministerial Order compliance)
  sectorRegistered   String?
  registrationNumber String?
  referredByCode     String?  // referral code used at group creation

  members              GroupMember[]
  inviteCodes          GroupInviteCode[]
  rotationLogs         RotationLog[]
  contributions        Contribution[]
  loans                Loan[]
  subscriptions        GroupSubscription[]
  subscriptionPayments SubscriptionPayment[]
  disputes             Dispute[]
  feedEvents           ActivityFeedEvent[]
  penaltyRules         PenaltyRule[]
  memberPenalties      MemberPenalty[]
  auctionBids          AuctionBid[]
  memberShareBalances  MemberShareBalance[]
  groupFund            GroupFund?
  waitlistEntries      WaitlistEntry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GroupMember {
  id       String   @id @default(uuid())
  groupId  String
  userId   String
  role     Role     @default(MEMBER)
  isActive Boolean  @default(true)
  joinedAt DateTime @default(now())

  group Group @relation(fields: [groupId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@unique([groupId, userId])
  @@index([userId, isActive])
  @@index([groupId, role, isActive])
}

model GroupInviteCode {
  id        String   @id @default(uuid())
  groupId   String
  code      String   @unique
  expiresAt DateTime
  group     Group    @relation(fields: [groupId], references: [id])
  createdAt DateTime @default(now())
}

model RotationLog {
  id            String   @id @default(uuid())
  groupId       String
  actorId       String
  previousOrder Json
  newOrder      Json
  randomSeed    String?
  group         Group    @relation(fields: [groupId], references: [id])
  createdAt     DateTime @default(now())
}

model Contribution {
  id                String             @id @default(uuid())
  groupId           String
  userId            String
  amount            Int
  weekNumber        Int
  status            ContributionStatus @default(PENDING)
  momoTransactionId String?
  bankReference     String?
  failureReason     String?
  verifiedAt        DateTime?
  verifiedById      String?

  sharesCount Int?
  shareValue  Int?

  group Group @relation(fields: [groupId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([groupId, userId, weekNumber, bankReference])
  @@index([userId, createdAt])
  @@index([groupId, weekNumber, status])
  @@index([groupId, userId, weekNumber])
  @@index([momoTransactionId])
}

model CreditScore {
  id          String   @id @default(uuid())
  userId      String   @unique
  score       Int
  label       String
  breakdown   Json
  lastUpdated DateTime @default(now())
}

model CreditScoreHistory {
  id        String   @id @default(uuid())
  userId    String
  score     Int
  label     String
  breakdown Json
  timestamp DateTime @default(now())

  @@index([userId, timestamp])
}

model SharedCreditReport {
  id         String                  @id @default(uuid())
  userId     String
  linkId     String                  @unique
  expiresAt  DateTime
  revoked    Boolean                 @default(false)
  user       User                    @relation(fields: [userId], references: [id])
  accessLogs SharedReportAccessLog[]
  createdAt  DateTime                @default(now())
}

model SharedReportAccessLog {
  id             String             @id @default(uuid())
  sharedReportId String
  ipAddress      String
  accessedAt     DateTime           @default(now())
  sharedReport   SharedCreditReport @relation(fields: [sharedReportId], references: [id])
}

model Loan {
  id              String     @id @default(uuid())
  groupId         String
  requesterId     String
  amount          Int
  interestAmount  Int        @default(0)
  totalRepayable  Int        @default(0)
  reason          String
  status          LoanStatus @default(PENDING)
  disbursedAt     DateTime?
  decidedById     String?
  decisionNote    String?
  repaymentMonths Int        @default(1)

  group      Group           @relation(fields: [groupId], references: [id])
  requester  User            @relation(fields: [requesterId], references: [id])
  repayments LoanRepayment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([requesterId, status, createdAt])
  @@index([groupId, status, createdAt])
}

enum MemberPenaltyStatus {
  PENDING
  PAID
}

model PenaltyRule {
  id          String  @id @default(uuid())
  groupId     String
  name        String
  description String?
  amount      Int
  isActive    Boolean @default(true)
  createdById String

  group           Group           @relation(fields: [groupId], references: [id])
  memberPenalties MemberPenalty[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MemberPenalty {
  id            String              @id @default(uuid())
  groupId       String
  userId        String
  penaltyRuleId String
  assignedById  String
  status        MemberPenaltyStatus @default(PENDING)
  bankReference String?
  paidAt        DateTime?
  note          String?

  group       Group       @relation(fields: [groupId], references: [id])
  user        User        @relation(fields: [userId], references: [id])
  penaltyRule PenaltyRule @relation(fields: [penaltyRuleId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, groupId, status])
  @@index([groupId, status, createdAt])
}

model LoanRepayment {
  id        String   @id @default(uuid())
  loanId    String
  amount    Int
  date      DateTime @default(now())
  loan      Loan     @relation(fields: [loanId], references: [id])
  createdAt DateTime @default(now())
}

model UssdSession {
  id        String           @id @default(uuid())
  sessionId String           @unique
  userId    String?
  state     UssdSessionState @default(OPEN)
  data      Json?
  user      User?            @relation(fields: [userId], references: [id])
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([userId, updatedAt])
  @@index([state, updatedAt])
}

model Notification {
  id          String              @id @default(uuid())
  recipientId String
  type        NotificationType
  message     String
  channel     NotificationChannel
  status      NotificationStatus  @default(PENDING)
  retryCount  Int                 @default(0)
  recipient   User                @relation(fields: [recipientId], references: [id])
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([recipientId, createdAt])
  @@index([status, createdAt])
}

model NotificationSetting {
  id      String           @id @default(uuid())
  userId  String
  type    NotificationType
  enabled Boolean          @default(true)
  user    User             @relation(fields: [userId], references: [id])

  @@unique([userId, type])
}

model GroupSubscription {
  id                   String             @id @default(uuid())
  groupId              String
  tier                 SubscriptionTier
  memberCountAtBilling Int
  amountDue            Int
  currency             String             @default("RWF")
  billingDate          DateTime
  status               SubscriptionStatus @default(TRIAL)
  trialEndsAt          DateTime?
  lastPaidAt           DateTime?
  nextBillingDate      DateTime

  group    Group                 @relation(fields: [groupId], references: [id])
  payments SubscriptionPayment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([groupId, createdAt])
  @@index([status, nextBillingDate])
}

model SubscriptionPayment {
  id                String        @id @default(uuid())
  groupId           String
  subscriptionId    String
  treasurerId       String
  amountPaid        Int
  momoTransactionId String?
  status            PaymentStatus @default(PENDING)
  attemptNumber     Int           @default(1)
  paidAt            DateTime?

  group        Group             @relation(fields: [groupId], references: [id])
  subscription GroupSubscription @relation(fields: [subscriptionId], references: [id])
  treasurer    User              @relation(fields: [treasurerId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([groupId, createdAt])
  @@index([subscriptionId, createdAt])
  @@index([status, createdAt])
}

model JobLock {
  id          String   @id @default(uuid())
  name        String   @unique
  owner       String
  lockedUntil DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Dispute {
  id               String        @id @default(uuid())
  groupId          String
  raiserId         String
  weekNumber       Int
  disputeType      DisputeType   @default(CONTRIBUTION_NOT_RECORDED)
  claimDescription String
  momoReference    String?
  status           DisputeStatus @default(OPEN)
  resolutionNote   String?

  group  Group @relation(fields: [groupId], references: [id])
  raiser User  @relation(fields: [raiserId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([groupId, status, createdAt])
  @@index([raiserId, status, createdAt])
}

model ActivityFeedEvent {
  id        String   @id @default(uuid())
  groupId   String
  type      String
  data      Json
  group     Group    @relation(fields: [groupId], references: [id])
  createdAt DateTime @default(now())
}

model AuditLog {
  id         String   @id @default(uuid())
  actorId    String?
  actionType String
  targetId   String?
  metadata   Json?
  actor      User?    @relation(fields: [actorId], references: [id])
  createdAt  DateTime @default(now())
}

model AuctionBid {
  id           String   @id @default(uuid())
  groupId      String
  memberId     String
  periodNumber Int
  bidAmount    Int
  submittedAt  DateTime @default(now())
  isWinning    Boolean  @default(false)
  group        Group    @relation(fields: [groupId], references: [id])
  member       User     @relation(fields: [memberId], references: [id])

  @@index([groupId, memberId, periodNumber])
  @@index([groupId, periodNumber, isWinning])
}

model MemberShareBalance {
  id                  String   @id @default(uuid())
  groupId             String
  memberId            String
  totalShares         Int      @default(0)
  currentPeriodShares Int      @default(0)
  lastUpdated         DateTime @default(now())
  group               Group    @relation(fields: [groupId], references: [id])
  member              User     @relation(fields: [memberId], references: [id])

  @@unique([groupId, memberId])
  @@index([memberId])
}

model GroupFund {
  id                  String   @id @default(uuid())
  groupId             String   @unique
  totalBalance        Int      @default(0)
  totalShares         Int      @default(0)
  totalInterestEarned Int      @default(0)
  activeLoanBalance   Int      @default(0)
  lastUpdated         DateTime @default(now())
  group               Group    @relation(fields: [groupId], references: [id])
}

model WaitlistEntry {
  id        String         @id @default(uuid())
  groupId   String
  userId    String
  status    WaitlistStatus @default(WAITING)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  group Group @relation(fields: [groupId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@unique([groupId, userId])
  @@index([groupId, status])
}

model ReferralLog {
  id             String   @id @default(uuid())
  referrerId     String
  referredUserId String
  groupId        String?
  status         String   @default("PENDING")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  referrer     User @relation("Referrer", fields: [referrerId], references: [id])
  referredUser User @relation("ReferredUser", fields: [referredUserId], references: [id])
}
